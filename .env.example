# ══════════════════════════════════════════════════════════════
# EXEMPLO DE CONFIGURAÇÃO - Copie para .env e preencha os valores
# ══════════════════════════════════════════════════════════════

# Banco de Dados PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/zendesk_evaluator

# Servidor
PORT=3001
JWT_SECRET=zendesk_evaluator_secret_2024

# Google OAuth (Login com Google)
# Para obter as credenciais:
# 1. Acesse https://console.cloud.google.com
# 2. Crie um novo projeto ou selecione existente
# 3. Ative a API "Google+ API"
# 4. Vá em "Credenciais" > "Criar credenciais" > "ID do cliente OAuth"
# 5. Tipo: Aplicativo da Web
# 6. Adicione em "URIs de redirecionamento autorizados":
#    http://localhost:3001/api/auth/google/callback
#    https://seudominio.com/api/auth/google/callback

GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret

# Zendesk (configurado via interface web em Configurações)
# ZENDESK_SUBDOMINIO=
# ZENDESK_EMAIL=
# ZENDESK_TOKEN=

# SMTP (configurado via interface web em Configurações)
# SMTP_SERVIDOR=
# SMTP_PORTA=587
# SMTP_USUARIO=
# SMTP_SENHA=

# IA Gemini (configurado via interface web em Configurações)
# IA_CHAVE_API=
